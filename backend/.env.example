# MeshSats Sync Engine Configuration

# The port the sync engine will listen on
PORT=8080

# Connectivity: Connection string for your Lightning Node (LND/CLN) or LSP
# Example for LND: https://127.0.0.1:10009
LIGHTNING_NODE_URI=your_lightning_node_uri_here
MACAROON_HEADER=your_macaroon_base64_here

# Risk & Reconciliation Strategy
# Values: FIRST_SEEN | AGENT_LED | MANUAL_REVIEW
RECONCILIATION_STRATEGY=FIRST_SEEN

# Maximum Sats allowed for a single offline-initiated intent
RISK_MAX_INTENT_SATS=50000

# Database for transaction queue (PostgreSQL/SQLite)
DATABASE_URL=postgres://user:pass@localhost:5432/meshsats
